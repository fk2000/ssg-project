---
interface Props {
	title: string;
	isMinecraft?: boolean;
}

const { title, isMinecraft = false } = Astro.props;

const siteName = isMinecraft ? "⛏️ Minecraft Tech Guide" : "✨ SSG Guide";
const homePath = isMinecraft ? "/minecraft/" : "/";
const accentColor = isMinecraft ? "#10b981" : "#6366f1";
const footerText = isMinecraft ? "Presented by Micra LOVE Club" : "SSG Guide Project";
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@700&display=swap" rel="stylesheet">
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-SMFLM7MS5Y"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-SMFLM7MS5Y');
		</script>
	</head>
	<body class={isMinecraft ? 'theme-minecraft' : 'theme-ssg'}>
		<header class="main-header reveal">
			<div class="header-content">
				<a href={homePath} class="logo">{siteName}</a>
				<nav class="main-nav">
					<a href={homePath}>Home</a>
					{!isMinecraft && <a href="/guide/ssg/01-introduction">Intro</a>}
					{isMinecraft && <a href="https://micraloveclub.fujiken.dev" target="_blank">Club</a>}
				</nav>
			</div>
		</header>
		<main class="page-container reveal">
			<slot />
		</main>
		<footer class="main-footer reveal">
			<div class="footer-content">
				<p>© 2026 {footerText}</p>
				<nav class="footer-links">
					<a href="https://fujiken.dev" target="_blank" rel="noopener noreferrer">fujiken.dev</a>
				</nav>
			</div>
		</footer>

		<!-- Mermaid Integration -->
		<script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
		<script is:inline>
			(function() {
				const initMermaid = () => {
					console.log("Mermaid logic starting...");
					if (typeof mermaid === 'undefined') {
						setTimeout(initMermaid, 200);
						return;
					}
					
					const isDark = document.body.classList.contains('theme-ssg');
					mermaid.initialize({
						startOnLoad: false,
						theme: isDark ? 'dark' : 'default',
						themeVariables: isDark ? {
							lineColor: '#94a3b8',
							textColor: '#f8fafc',
							mainBkg: '#1e293b',
							nodeBorder: '#475569',
						} : {},
						fontFamily: 'Inter, system-ui, sans-serif',
						securityLevel: 'loose',
					});

					const mermaidBlocks = document.querySelectorAll('pre[data-language="mermaid"], pre code.language-mermaid, pre.mermaid');
					console.log(`Found ${mermaidBlocks.length} target blocks`);
					
					mermaidBlocks.forEach(async (block, index) => {
						if (block.getAttribute('data-mermaid-processed')) return;
						
						// テキストの抽出とクリーンアップ
						let code = (block.innerText || block.textContent).trim();
						// もし ```mermaid ... ``` が含まれていたら中身だけ抜く
						code = code.replace(/^```mermaid\s*/, '').replace(/```$/, '').trim();
						
						if (!code) return;

						const id = 'mermaid-render-' + index;
						const parent = block.closest('pre') || block;
						
						try {
							// 非同期でレンダリング
							const { svg } = await mermaid.render(id, code);
							
							const container = document.createElement('div');
							container.className = 'mermaid-container';
							container.style.display = 'flex';
							container.style.justifyContent = 'center';
							container.style.margin = '2rem 0';
							container.style.padding = '1.5rem';
							container.style.background = isDark ? 'rgba(255, 255, 255, 0.03)' : 'rgba(0, 0, 0, 0.02)';
							container.style.borderRadius = '12px';
							container.style.width = '100%';
							container.style.overflowX = 'auto';
							container.innerHTML = svg;
							container.style.cursor = 'zoom-in';
							
							container.addEventListener('click', () => {
								const modal = document.getElementById('mermaid-modal');
								const modalContent = document.getElementById('mermaid-modal-content');
								if (modal && modalContent) {
									modalContent.innerHTML = svg;
									modal.classList.add('active');
									document.body.style.overflow = 'hidden';
								}
							});
							
							if (parent && parent.parentNode) {
								parent.parentNode.replaceChild(container, parent);
								container.setAttribute('data-mermaid-processed', 'true');
								console.log(`Rendered mermaid block ${index}`);
							}
						} catch (error) {
							console.error(`Mermaid render failed for block ${index}:`, error);
							// 失敗した場合はエラー表示を出すか、そのままにする
							const errorMsg = document.createElement('div');
							errorMsg.style.color = '#ef4444';
							errorMsg.style.fontSize = '0.8rem';
							errorMsg.textContent = 'Mermaid 描画エラー: 構文を確認してください';
							parent.before(errorMsg);
						}
					});
				};

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', initMermaid);
				} else {
					initMermaid();
				}
			})();
		</script>
		<div id="mermaid-modal" class="mermaid-modal">
			<div id="mermaid-modal-content" class="mermaid-modal-content"></div>
			<button class="modal-close">&times;</button>
		</div>

		<script is:inline>
			// モダルを閉じる処理
			document.addEventListener('DOMContentLoaded', () => {
				const modal = document.getElementById('mermaid-modal');
				if (modal) {
					const closeModal = () => {
						modal.classList.remove('active');
						document.body.style.overflow = '';
					};
					modal.addEventListener('click', closeModal);
					document.addEventListener('keydown', (e) => {
						if (e.key === 'Escape') closeModal();
					});
				}
			});
		</script>
	</body>
</html>

<style is:global define:vars={{ primaryColor: accentColor }}>
	@import "../styles/global.css";

	:root {
		--primary: var(--primaryColor);
	}

	/* --- Common Styles --- */
	.mermaid {
		display: flex;
		justify-content: center;
		margin: 2rem 0;
		background: rgba(255, 255, 255, 0.03);
		padding: 2rem;
		border-radius: 12px;
	}
	.theme-minecraft .mermaid {
		background: rgba(255, 255, 255, 0.6);
		border: 2px solid #388e3c;
		box-shadow: 4px 4px 0 #388e3c;
	}

	/* --- Mermaid Modal --- */
	.mermaid-modal {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.85);
		backdrop-filter: blur(10px);
		z-index: 9999;
		display: none;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		cursor: zoom-out;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.mermaid-modal.active {
		display: flex;
		opacity: 1;
	}

	.mermaid-modal-content {
		max-width: 95%;
		max-height: 90vh;
		background: #fff;
		padding: 3rem;
		border-radius: 20px;
		overflow: auto;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
		transform: scale(0.95);
		transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.mermaid-modal.active .mermaid-modal-content {
		transform: scale(1);
	}

	.theme-ssg .mermaid-modal-content {
		background: #1e293b;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.modal-close {
		position: absolute;
		top: 2rem;
		right: 2rem;
		background: none;
		border: none;
		color: #fff;
		font-size: 3rem;
		cursor: pointer;
		line-height: 1;
		opacity: 0.7;
		transition: opacity 0.2s;
	}

	.modal-close:hover {
		opacity: 1;
	}

	.mermaid-container svg {
		height: auto !important;
		max-width: 100% !important;
	}

	.mermaid-modal-content svg {
		width: 100% !important;
		height: auto !important;
	}
	.main-header {
		position: sticky;
		top: 0;
		z-index: 100;
		backdrop-filter: blur(12px);
		padding: 1rem 0;
		transition: all 0.3s ease;
	}

	.header-content {
		max-width: 1000px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 2rem;
	}

	.logo {
		font-family: 'Outfit', sans-serif;
		font-weight: 700;
		font-size: 1.5rem;
		letter-spacing: -0.02em;
		text-decoration: none;
	}

	.main-nav { display: flex; gap: 2rem; }
	.main-nav a { text-decoration: none; font-weight: 600; transition: color 0.2s; }

	.page-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 4rem 2rem;
	}

	.main-footer {
		margin-top: 8rem;
		padding: 4rem 2rem;
		transition: all 0.3s ease;
	}

	.footer-content {
		max-width: 1000px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.9rem;
	}

	.footer-links a { font-weight: 600; text-decoration: none; }

	/* --- SSG Theme (Dark) --- */
	.theme-ssg {
		background: #0f172a;
		color: #f8fafc;
	}
	.theme-ssg .main-header {
		background: rgba(15, 23, 42, 0.8);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	.theme-ssg .logo { color: #fff; }
	.theme-ssg .main-nav a { color: var(--text-muted); }
	.theme-ssg .main-nav a:hover { color: var(--primary); }
	.theme-ssg .main-footer {
		background: rgba(15, 23, 42, 0.4);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		color: var(--text-muted);
	}
	.theme-ssg .footer-links a { color: var(--primary); }

	/* --- Minecraft Theme (Bright/Kids) --- */
	.theme-minecraft {
		background: #e0faff; /* 澄み切った空色 */
		color: #064e3b; /* 濃い緑の文字色 */
		--text-muted: #374151; /* 読みやすい濃いグレー */
	}

	.theme-minecraft .main-header {
		background: #2e7d32;
		border-bottom: 6px solid #1b5e20;
		box-shadow: 0 4px 15px rgba(0,0,0,0.1);
	}
	.theme-minecraft .logo { color: #fff; text-shadow: 2px 2px 0 #1b5e20, 4px 4px 0 rgba(0,0,0,0.1); }
	.theme-minecraft .main-nav a { color: #fff !important; }
	.theme-minecraft .main-nav a:hover { color: #c8e6c9 !important; }
	
	.theme-minecraft .glass-card {
		background: #ffffff;
		border: 4px solid #388e3c;
		box-shadow: 10px 10px 0 #a7f3d0;
		color: #064e3b;
	}
	
	/* 飛んでいた文字（メタデータや説明文）を濃くする */
	.theme-minecraft .post-title,
	.theme-minecraft .chapter-label,
	.theme-minecraft .chapter-description,
	.theme-minecraft .collection-title,
	.theme-minecraft .hero-subtitle,
	.theme-minecraft .post-summary,
	.theme-minecraft .post-meta,
	.theme-minecraft .chapter-tag,
	.theme-minecraft .tag,
	.theme-minecraft .sidebar-title,
	.theme-minecraft .link-text,
	.theme-minecraft .back-home {
		color: #065f46 !important; /* すべて濃い緑〜緑青色に強制 */
		text-shadow: none !important;
		opacity: 1 !important;
	}

	.theme-minecraft .prose {
		color: #1f2937 !important;
	}
	.theme-minecraft .prose h1, 
	.theme-minecraft .prose h2, 
	.theme-minecraft .prose h3 {
		color: #064e3b !important;
	}

	/* サイドバーとナビゲーション */
	.theme-minecraft .sidebar {
		background: rgba(255, 255, 255, 0.85);
		border-right: 5px solid #10b981;
	}
	.theme-minecraft .toc-nav a { color: #065f46 !important; }
	.theme-minecraft .toc-nav a:hover { background: #d1fae5; }
	.theme-minecraft .toc-nav a.active { background: #059669; color: #fff !important; }
	.theme-minecraft .order-num { color: #059669; opacity: 1; font-weight: bold; }

	.theme-minecraft .main-footer {
		background: #1b5e20;
		border-top: 6px solid #064e3b;
		color: #ecfdf5;
	}
	.theme-minecraft .footer-links a { color: #fff; border-bottom: 2px solid #34d399; }

	/* Animations */
	.reveal {
		animation: reveal 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
	}
	@keyframes reveal {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
