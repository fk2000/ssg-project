---
interface Props {
	title: string;
	isMinecraft?: boolean;
}

const { title, isMinecraft = false } = Astro.props;

const siteName = isMinecraft ? "⛏️ Minecraft Tech Guide" : "✨ SSG Guide";
const homePath = isMinecraft ? "/minecraft/" : "/";
const accentColor = isMinecraft ? "#10b981" : "#6366f1";
const footerText = isMinecraft ? "Presented by Micra LOVE Club" : "SSG Guide Project";
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@700&display=swap" rel="stylesheet">
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-SMFLM7MS5Y"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-SMFLM7MS5Y');
		</script>
	</head>
	<body class={isMinecraft ? 'theme-minecraft' : 'theme-ssg'}>
		<header class="main-header reveal">
			<div class="header-content">
				<a href={homePath} class="logo">{siteName}</a>
				<nav class="main-nav">
					<a href={homePath}>Home</a>
					{!isMinecraft && <a href="/guide/ssg/01-introduction">Intro</a>}
					{isMinecraft && <a href="https://micraloveclub.fujiken.dev" target="_blank">Club</a>}
				</nav>
			</div>
		</header>
		<main class="page-container reveal">
			<slot />
		</main>
		<footer class="main-footer reveal">
			<div class="footer-content">
				<p>© 2026 {footerText}</p>
				<nav class="footer-links">
					<a href="https://fujiken.dev" target="_blank" rel="noopener noreferrer">fujiken.dev</a>
				</nav>
			</div>
		</footer>
	</body>
</html>

<style is:global define:vars={{ primaryColor: accentColor }}>
	@import "../styles/global.css";

	:root {
		--primary: var(--primaryColor);
	}

	/* --- Common Styles --- */
	.main-header {
		position: sticky;
		top: 0;
		z-index: 100;
		backdrop-filter: blur(12px);
		padding: 1rem 0;
		transition: all 0.3s ease;
	}

	.header-content {
		max-width: 1000px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 2rem;
	}

	.logo {
		font-family: 'Outfit', sans-serif;
		font-weight: 700;
		font-size: 1.5rem;
		letter-spacing: -0.02em;
		text-decoration: none;
	}

	.main-nav { display: flex; gap: 2rem; }
	.main-nav a { text-decoration: none; font-weight: 600; transition: color 0.2s; }

	.page-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 4rem 2rem;
	}

	.main-footer {
		margin-top: 8rem;
		padding: 4rem 2rem;
		transition: all 0.3s ease;
	}

	.footer-content {
		max-width: 1000px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.9rem;
	}

	.footer-links a { font-weight: 600; text-decoration: none; }

	/* --- SSG Theme (Dark) --- */
	.theme-ssg {
		background: #0f172a;
		color: #f8fafc;
	}
	.theme-ssg .main-header {
		background: rgba(15, 23, 42, 0.8);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	.theme-ssg .logo { color: #fff; }
	.theme-ssg .main-nav a { color: var(--text-muted); }
	.theme-ssg .main-nav a:hover { color: var(--primary); }
	.theme-ssg .main-footer {
		background: rgba(15, 23, 42, 0.4);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		color: var(--text-muted);
	}
	.theme-ssg .footer-links a { color: var(--primary); }

	/* --- Minecraft Theme (Bright/Kids) --- */
	.theme-minecraft {
		background: #e0f2fe; /* Light sky blue */
		color: #1e3a8a;
	}
	.theme-minecraft .main-header {
		background: #2e7d32; /* Grass green */
		border-bottom: 5px solid #1b5e20;
		box-shadow: 0 4px 10px rgba(0,0,0,0.1);
	}
	.theme-minecraft .logo { color: #fff; text-shadow: 2px 2px 0 #1b5e20; }
	.theme-minecraft .main-nav a { color: #fff; }
	.theme-minecraft .main-nav a:hover { color: #c8e6c9; }
	
	.theme-minecraft .glass-card {
		background: #fff;
		border: 4px solid #388e3c;
		border-radius: 0; /* Square/Blocky */
		box-shadow: 8px 8px 0 #c8e6c9;
		color: #1b5e20;
	}
	.theme-minecraft .post-title, .theme-minecraft .chapter-label { 
		color: #1b5e20; font-weight: 800;
	}
	.theme-minecraft .prose { color: #334155; }
	.theme-minecraft .prose h1, .theme-minecraft .prose h2 { color: #1b5e20; }
	
	.theme-minecraft .sidebar {
		background: rgba(255, 255, 255, 0.7);
		border-right: 4px solid #388e3c;
		border-radius: 0 20px 20px 0;
	}
	.theme-minecraft .toc-nav a { color: #2e7d32; }
	.theme-minecraft .toc-nav a.active { background: #388e3c; color: #fff; }

	.theme-minecraft .main-footer {
		background: #2e7d32;
		border-top: 5px solid #1b5e20;
		color: #fff;
	}
	.theme-minecraft .footer-links a { color: #fff; border-bottom: 2px solid #fff; }

	/* Animations */
	.reveal {
		animation: reveal 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
	}
	@keyframes reveal {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
