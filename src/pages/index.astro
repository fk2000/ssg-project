---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// SSGガイドの記事のみを取得
const allGuidePosts = await getCollection('ssg-guide');
const sortedPosts = allGuidePosts.sort((a, b) => {
  if (a.data.chapter !== b.data.chapter) return (a.data.chapter ?? 0) - (b.data.chapter ?? 0);
  return (a.data.order ?? 99) - (b.data.order ?? 99);
});

// SSGガイド用のチャプター定義
const chapters = [
  { id: 1, title: 'Chapter 1: 基礎知識と導入', description: 'SSGの基本概念と、本サイトを構築している Astro の魅力について学びます。' },
  { id: 2, title: 'Chapter 2: 主要 SSG カタログ', description: '目的や言語に合わせて、最適な静的サイトジェネレーターを選択するための徹底比較。' },
  { id: 3, title: 'Chapter 3: 実践・高度な運用術', description: 'デプロイ自動化、独自ドメイン、SEO、計測環境など、プロフェッショナルな運用手法。' }
];
---

<Layout title="SSGガイド - プロフェッショナルな静的サイト制作">
  <div class="hero-section">
    <h1 class="hero-title">🚀 SSG Guide</h1>
    <p class="hero-subtitle">静的サイトジェネレーターの世界を体系的に学ぶための専門ドキュメント。最新のトレンドと実践法を解説します。</p>
  </div>
    
  <div class="toc-container">
    {chapters.map(chapter => (
      <section class="chapter-section">
        <div class="chapter-header">
          <h2 class="chapter-label">{chapter.title}</h2>
          <p class="chapter-description">{chapter.description}</p>
        </div>

        <div class="posts-grid">
          {sortedPosts.filter(post => (post.data.chapter ?? 1) === chapter.id).map(post => (
            <div class="glass-card post-card">
              <a href={`/guide/ssg/${post.id}`} class="post-link">
                <div class="post-meta">
                  <span class="type-badge">節 {post.data.order ?? '?'}</span>
                  <span class={`status-badge ${post.data.status}`}>
                    {post.data.status === 'published' ? 'Live' : 'Draft'}
                  </span>
                </div>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-summary">{post.data.summary || "概要は準備中です。"}</p>
              </a>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</Layout>

<style>
  /* 以前の美しいスタイルを維持 */
  .hero-section { text-align: center; margin-bottom: 6rem; }
  .hero-title {
    font-size: 4.5rem;
    background: linear-gradient(135deg, #fff 0%, #6366f1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1.5rem;
    font-weight: 800;
  }
  .hero-subtitle { font-size: 1.35rem; color: var(--text-muted); max-width: 700px; margin: 0 auto; }
  .chapter-section { margin-bottom: 6rem; }
  .chapter-header { margin-bottom: 3rem; padding-left: 1.5rem; border-left: 4px solid var(--primary); }
  .chapter-label { font-size: 2rem; color: #fff; margin-bottom: 0.5rem; }
  .chapter-description { color: var(--text-muted); font-size: 1.1rem; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; }
  .post-card { padding: 2rem; height: 100%; }
  .post-link { display: flex; flex-direction: column; height: 100%; color: inherit; text-decoration: none; }
  .post-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .type-badge { font-size: 0.7rem; color: var(--primary); background: rgba(99, 102, 241, 0.1); padding: 0.2rem 0.6rem; border-radius: 4px; }
  .status-badge { font-size: 0.65rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 4px; text-transform: uppercase; }
  .status-badge.published { background: #059669; color: #ecfdf5; }
  .status-badge.draft { background: #475569; color: #f1f5f9; }
  .post-title { font-size: 1.4rem; color: #fff; margin-bottom: 1rem; line-height: 1.3; }
  .post-summary { font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; }
</style>
