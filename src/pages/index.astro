---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// 全ての記事を取得
const ssgPosts = await getCollection('ssg-guide');
const minecraftPosts = await getCollection('minecraft-java-function');

const collections = [
  {
    id: 'ssg',
    title: '🚀 SSGガイド プロジェクト',
    description: '静的サイトジェネレーターの世界を学ぶためのドキュメント。',
    posts: ssgPosts.sort((a, b) => (a.data.chapter ?? 0) - (b.data.chapter ?? 0) || (a.data.order ?? 99) - (b.data.order ?? 99)),
    path: 'ssg'
  },
  {
    id: 'minecraft',
    title: '⛏️ Minecraft Java Edition ガイド',
    description: 'Function機能を活用した地上絵作成と、サーバーホスティングの解説。',
    posts: minecraftPosts.sort((a, b) => (a.data.chapter ?? 0) - (b.data.chapter ?? 0) || (a.data.order ?? 99) - (b.data.order ?? 99)),
    path: 'mc'
  }
];
---

<Layout title="技術ドキュメント Hub">
  <div class="hero-section">
    <h1 class="hero-title">Developer Hub</h1>
    <p class="hero-subtitle">専門的な技術ナレッジを体系的に整理した、fk2000 のナレッジベースです。</p>
  </div>
    
  <div class="collections-container">
    {collections.map(coll => (
      <section class="collection-section">
        <div class="collection-header">
          <h2 class="collection-title">{coll.title}</h2>
          <p class="collection-description">{coll.description}</p>
        </div>

        <div class="posts-grid">
          {coll.posts.map(post => (
            <div class="glass-card post-card">
              <a href={`/guide/${coll.path}/${post.id}`} class="post-link">
                <div class="post-meta">
                  <span class="chapter-label">Ch.{post.data.chapter}</span>
                  <span class={`status-badge ${post.data.status}`}>
                    {post.data.status === 'published' ? 'Live' : 'Draft'}
                  </span>
                </div>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-summary">{post.data.summary || "概要は準備中です。"}</p>
              </a>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</Layout>

<style>
  .hero-section {
    text-align: center;
    margin-bottom: 6rem;
  }

  .hero-title {
    font-size: 4.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #fff 0%, #6366f1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
  }

  .collection-section {
    margin-bottom: 8rem;
  }

  .collection-header {
    margin-bottom: 4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 2rem;
  }

  .collection-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: #fff;
  }

  .collection-description {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .post-card {
    padding: 2rem;
    transition: transform 0.3s ease;
  }

  .post-card:hover {
    transform: translateY(-5px);
  }

  .post-link {
    text-decoration: none;
    color: inherit;
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .chapter-label {
    font-family: var(--font-mono);
    color: var(--primary);
    font-weight: bold;
  }

  .status-badge {
    font-size: 0.6rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .status-badge.published { background: rgba(5, 150, 105, 0.2); color: #10b981; }
  .status-badge.draft { background: rgba(71, 85, 105, 0.2); color: #94a3b8; }

  .post-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #fff;
    line-height: 1.4;
  }

  .post-summary {
    font-size: 0.9rem;
    color: var(--text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
