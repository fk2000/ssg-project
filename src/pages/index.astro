---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// 全ての記事を取得し、order（順序）に基づいて並び替えます
const allGuidePosts = await getCollection('ssg-guide');
const sortedPosts = allGuidePosts.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// フロントエンドでの表示用デバッグ（コンソールに記事リストを出力）
// console.log(sortedPosts);
---

<Layout title="SSGガイド - 目次">
  <div class="hero-section">
    <h1 class="hero-title">📚 SSGガイド プロジェクト</h1>
    <p class="hero-subtitle">静的サイトジェネレーターの世界を学ぶための、体系的でモダンなドキュメント。最新の技術トレンドと実践法を解説します。</p>
  </div>
    
  <div class="toc-container">
    <h2 class="section-title">目次</h2>
    <nav>
      <div class="posts-grid">
        {sortedPosts.map(post => {
          const isPublished = post.data.status === 'published';
          return (
            <div class="glass-card post-card">
              <a href={`/guide/${post.id}`} class="post-link">
                <div class="post-meta">
                  <span class="chapter-badge">Chapter {post.data.chapter ?? '?'}</span>
                  <span class={`status-badge ${post.data.status}`}>
                    {isPublished ? 'Live' : 'Draft'}
                  </span>
                </div>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-summary">{post.data.summary || "概要は準備中です。"}</p>
                
                {post.data.tags && (
                  <div class="tags-container">
                    {post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
                  </div>
                )}
              </a>
            </div>
          );
        })}
      </div>
    </nav>
  </div>
</Layout>

<style>
  .hero-section {
    text-align: center;
    margin-bottom: 5rem;
  }

  .hero-title {
    font-size: 3.5rem;
    background: linear-gradient(135deg, #fff 0%, #6366f1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    padding-left: 1rem;
    border-left: 4px solid var(--primary);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .post-card {
    padding: 2rem;
    height: 100%;
  }

  .post-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .chapter-badge {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--primary);
    background: rgba(99, 102, 241, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    border: 1px solid rgba(99, 102, 241, 0.2);
  }

  .status-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .status-badge.published { background: #059669; color: #ecfdf5; }
  .status-badge.draft { background: #475569; color: #f1f5f9; }

  .post-title {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .post-summary {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--primary);
    opacity: 0.8;
  }
</style>
