---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Comments from '../../components/Comments.astro';

export async function getStaticPaths() {
  const allGuidePosts = await getCollection('ssg-guide');
  return allGuidePosts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

// サイドバー用に全記事を取得
const allPosts = await getCollection('ssg-guide');
const sortedPosts = allPosts.sort((a, b) => {
  if (a.data.chapter !== b.data.chapter) return (a.data.chapter ?? 0) - (b.data.chapter ?? 0);
  return (a.data.order ?? 0) - (b.data.order ?? 0);
});

// 章ごとにグループ化
const chapters = [...new Set(sortedPosts.map(p => p.data.chapter ?? 0))].sort();

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | SSG Guide`}>
  <div class="book-shell">
    <!-- サイドバー -->
    <aside class="sidebar">
      <div class="sidebar-inner glass-card">
        <h2 class="sidebar-title">目次</h2>
        <nav class="sidebar-nav">
          {chapters.map(chNumber => (
            <details open class="chapter-group">
              <summary class="chapter-header">
                Chapter {chNumber === 0 ? 'Intro' : chNumber}
                <span class="chevron">›</span>
              </summary>
              <ul class="chapter-list">
                {sortedPosts.filter(p => (p.data.chapter ?? 0) === chNumber).map(p => (
                  <li>
                    <a href={`/guide/${p.id}`} class={`nav-link ${p.id === post.id ? 'active' : ''}`}>
                      {p.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))}
        </nav>
      </div>
    </aside>

    <!-- メインコンテンツ -->
    <article class="post-article">
      <header class="post-header">
        <div class="post-breadcrumb">
          <a href="/">Guide</a> / <span class="current">Chapter {post.data.chapter ?? '?'}</span>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-info">
          <span class={`status-tag ${post.data.status}`}>{post.data.status}</span>
        </div>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <Comments />

      <footer class="post-footer">
        <hr class="footer-divider" />
        <div class="footer-actions">
          <a href="/" class="back-link">
            <span class="arrow">←</span> 目次へ戻る
          </a>
        <!-- <a 
            href={`https://bitbucket.org/fk2000/vigorous-venus/src/main/src/content/ssg-guide/${post.id}.md`} 
            target="_blank" 
            class="edit-link"
          >
            <span class="icon">✎</span> このページを編集する
          </a> -->
        </div>
      </footer>
    </article>
  </div>
</Layout>

<style>
  .book-shell {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* サイドバー設定 */
  .sidebar {
    position: sticky;
    top: 6rem;
    height: calc(100vh - 8rem);
  }

  .sidebar-inner {
    height: 100%;
    padding: 2rem;
    overflow-y: auto;
  }

  .sidebar-title {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    color: var(--primary);
  }

  .chapter-group {
    margin-bottom: 1rem;
  }

  .chapter-header {
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    font-size: 0.9rem;
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .chapter-header::-webkit-details-marker { display: none; }

  .chevron {
    transition: transform 0.3s ease;
    font-size: 1.2rem;
    color: var(--text-muted);
  }

  .chapter-group[open] .chevron {
    transform: rotate(90deg);
  }

  .chapter-list {
    list-style: none;
    padding-left: 0.5rem;
    margin: 0.5rem 0 1.5rem 0;
    border-left: 1px solid var(--border);
  }

  .nav-link {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.95rem;
    color: var(--text-muted);
    border-radius: 6px;
    margin-bottom: 2px;
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--primary);
  }

  .nav-link.active {
    background: rgba(99, 102, 241, 0.1);
    color: var(--primary);
    font-weight: 600;
  }

  /* 記事エリア：GitHub クリーン・スタイル */
  .post-article {
    max-width: 840px;
    background: #ffffff;
    color: #1f2328; /* GitHub Text Color */
    padding: 3rem 4rem;
    border-radius: 12px;
    border: 1px solid #d0d7de; /* GitHub Border */
    box-shadow: 0 8px 24px rgba(149, 157, 165, 0.2);
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #d0d7de;
  }

  .post-breadcrumb {
    font-size: 0.9rem;
    color: #636c76;
    margin-bottom: 1rem;
  }

  .post-breadcrumb a {
    color: #0969da;
  }

  .post-title {
    font-size: 2.25rem;
    margin-bottom: 1rem;
    font-weight: 600;
    line-height: 1.25;
    color: #1f2328;
    background: none;
    -webkit-text-fill-color: initial;
  }

  .post-info {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  /* ステータスタグの修正（GitHub Label風） */
  .status-tag {
    font-size: 12px;
    font-weight: 600;
    padding: 2px 10px;
    border-radius: 2em;
    border: 1px solid transparent;
  }

  .status-tag.published {
    background-color: #dafbe1;
    color: #1a7f37;
    border-color: rgba(26, 127, 55, 0.2);
  }

  .status-tag.draft {
    background-color: #fff8c5;
    color: #9a6700;
    border-color: rgba(154, 103, 0, 0.2);
  }

  .post-content {
    font-size: 16px;
    line-height: 1.6;
    color: #1f2328;
  }

  .post-content h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2rem 0 1rem 0;
    padding-bottom: 0.3em;
    border-bottom: 1px solid #d0d7de;
    color: #1f2328;
  }

  .post-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 1.5rem 0 1rem 0;
    color: #1f2328;
  }

  .post-content p {
    margin-bottom: 1rem;
  }

  /* リンクの視認性向上 */
  .post-content a {
    color: #0969da;
    text-decoration: none;
  }

  .post-content a:hover {
    text-decoration: underline;
  }

  .post-content strong {
    font-weight: 600;
    color: #1f2328;
  }

  .post-content ul, .post-content ol {
    margin-bottom: 1rem;
    padding-left: 2rem;
  }

  .post-content li {
    margin-bottom: 0.25rem;
  }

  .post-content blockquote {
    margin: 0 0 1rem 0;
    padding: 0 1em;
    color: #636c76;
    border-left: 0.25em solid #d0d7de;
  }

  .post-content code:not(pre code) {
    padding: 0.2em 0.4em;
    margin: 0;
    font-size: 85%;
    white-space: break-spaces;
    background-color: rgba(175, 184, 193, 0.2);
    border-radius: 6px;
    color: #1f2328;
    font-family: ui-monospace, SFMono-Regular, SF Mono, Menlo, Consolas, Liberation Mono, monospace;
  }

  /* フッターアクション */
  .footer-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 3rem;
  }

  .back-link {
    color: #0969da;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .edit-link {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .back-link:hover, .edit-link:hover {
    opacity: 1;
    color: var(--primary);
  }

  .edit-link:hover {
    background: rgba(99, 102, 241, 0.1);
    border-color: var(--primary);
  }

  .arrow, .icon {
    transition: transform 0.3s ease;
  }

  .back-link:hover .arrow {
    transform: translateX(-5px);
  }

  .edit-link:hover .icon {
    transform: rotate(15deg) scale(1.1);
  }

  @media (max-width: 900px) {
    .book-shell {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
      height: auto;
      margin-bottom: 3rem;
    }
  }
</style>
