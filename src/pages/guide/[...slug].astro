---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allGuidePosts = await getCollection('ssg-guide');
  return allGuidePosts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

// サイドバー用に全記事を取得
const allPosts = await getCollection('ssg-guide');
const sortedPosts = allPosts.sort((a, b) => {
  if (a.data.chapter !== b.data.chapter) return (a.data.chapter ?? 0) - (b.data.chapter ?? 0);
  return (a.data.order ?? 0) - (b.data.order ?? 0);
});

// 章ごとにグループ化
const chapters = [...new Set(sortedPosts.map(p => p.data.chapter ?? 0))].sort();

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | SSG Guide`}>
  <div class="book-shell">
    <!-- サイドバー -->
    <aside class="sidebar">
      <div class="sidebar-inner glass-card">
        <h2 class="sidebar-title">目次</h2>
        <nav class="sidebar-nav">
          {chapters.map(chNumber => (
            <details open class="chapter-group">
              <summary class="chapter-header">
                Chapter {chNumber === 0 ? 'Intro' : chNumber}
                <span class="chevron">›</span>
              </summary>
              <ul class="chapter-list">
                {sortedPosts.filter(p => (p.data.chapter ?? 0) === chNumber).map(p => (
                  <li>
                    <a href={`/guide/${p.id}`} class={`nav-link ${p.id === post.id ? 'active' : ''}`}>
                      {p.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))}
        </nav>
      </div>
    </aside>

    <!-- メインコンテンツ -->
    <article class="post-article">
      <header class="post-header">
        <div class="post-breadcrumb">
          <a href="/">Guide</a> / <span class="current">Chapter {post.data.chapter ?? '?'}</span>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-info">
          <span class={`status-tag ${post.data.status}`}>{post.data.status}</span>
        </div>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <footer class="post-footer">
        <hr class="footer-divider" />
        <a href="/" class="back-link">← 目次へ戻る</a>
      </footer>
    </article>
  </div>
</Layout>

<style>
  .book-shell {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* サイドバー設定 */
  .sidebar {
    position: sticky;
    top: 6rem;
    height: calc(100vh - 8rem);
  }

  .sidebar-inner {
    height: 100%;
    padding: 2rem;
    overflow-y: auto;
  }

  .sidebar-title {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    color: var(--primary);
  }

  .chapter-group {
    margin-bottom: 1rem;
  }

  .chapter-header {
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    font-size: 0.9rem;
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .chapter-header::-webkit-details-marker { display: none; }

  .chevron {
    transition: transform 0.3s ease;
    font-size: 1.2rem;
    color: var(--text-muted);
  }

  .chapter-group[open] .chevron {
    transform: rotate(90deg);
  }

  .chapter-list {
    list-style: none;
    padding-left: 0.5rem;
    margin: 0.5rem 0 1.5rem 0;
    border-left: 1px solid var(--border);
  }

  .nav-link {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.95rem;
    color: var(--text-muted);
    border-radius: 6px;
    margin-bottom: 2px;
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--primary);
  }

  .nav-link.active {
    background: rgba(99, 102, 241, 0.1);
    color: var(--primary);
    font-weight: 600;
  }

  /* 記事エリア */
  .post-article {
    max-width: 800px;
  }

  .post-header {
    margin-bottom: 3rem;
  }

  .post-title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .status-tag {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-muted);
  }

  .post-content {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  @media (max-width: 900px) {
    .book-shell {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
      height: auto;
      margin-bottom: 3rem;
    }
  }
</style>
