---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 全ての記事データを取得して、それぞれのパスを生成します
export async function getStaticPaths() {
  const allGuidePosts = await getCollection('ssg-guide');
  return allGuidePosts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
// render() 関数を使って Markdown コンテンツを変換します
const { Content } = await render(post);
---

<Layout title={post.data.title}>
  <article class="post-article">
    <header class="post-header">
      <div class="post-breadcrumb">
        <a href="/">Guide</a> / <span class="current">Chapter {post.data.chapter ?? '?'}</span>
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-info">
        <span class={`status-tag ${post.data.status}`}>{post.data.status}</span>
        <span class="post-date">Reading Time: ~5 min</span>
      </div>
      {post.data.summary && <p class="post-excerpt">{post.data.summary}</p>}
    </header>

    <div class="post-content">
      <Content />
    </div>

    <footer class="post-footer">
      <hr class="footer-divider" />
      <div class="footer-actions">
        <a href="/" class="back-link">
          <span class="arrow">←</span> 目次へ戻る
        </a>
      </div>
    </footer>
  </article>
</Layout>

<style>
  .post-article {
    max-width: 800px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 4rem;
    text-align: center;
  }

  .post-breadcrumb {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .post-breadcrumb .current {
    color: var(--primary);
    font-weight: 600;
  }

  .post-title {
    font-size: 3rem;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .post-info {
    display: flex;
    justify-content: center;
    gap: 1rem;
    align-items: center;
    margin-bottom: 2rem;
  }

  .status-tag {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    text-transform: uppercase;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .status-tag.published { background: rgba(5, 150, 105, 0.2); color: #34d399; border-color: rgba(52, 211, 153, 0.3); }
  .status-tag.draft { background: rgba(71, 85, 105, 0.2); color: #94a3b8; }

  .post-date {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .post-excerpt {
    font-size: 1.2rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
    font-style: italic;
  }

  .post-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.9);
  }

  .post-footer {
    margin-top: 6rem;
  }

  .footer-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: var(--on-surface);
    opacity: 0.7;
  }

  .back-link:hover {
    opacity: 1;
    color: var(--primary);
  }

  .arrow {
    transition: transform 0.3s ease;
  }

  .back-link:hover .arrow {
    transform: translateX(-5px);
  }
</style>
