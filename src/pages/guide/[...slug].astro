---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Comments from '../../components/Comments.astro';
import ZennMessage from '../../components/ZennMessage.astro';

export async function getStaticPaths() {
  const ssgPosts = await getCollection('ssg-guide');
  const mcPosts = await getCollection('minecraft-java-function');
  
  const allPosts = [
    ...ssgPosts.map(post => ({ params: { slug: `ssg/${post.id}` }, props: { post, collection: 'ssg-guide' } })),
    ...mcPosts.map(post => ({ params: { slug: `mc/${post.id}` }, props: { post, collection: 'minecraft-java-function' } }))
  ];

  return allPosts;
}

const { post, collection } = Astro.props;
const { Content, headings } = await render(post);

// サイドバー用のデータを、同じコレクション内から取得
const allCollectionPosts = await getCollection(collection);
const sortedPosts = allCollectionPosts.sort((a, b) => {
  if (a.data.chapter !== b.data.chapter) return (a.data.chapter ?? 0) - (b.data.chapter ?? 0);
  return (a.data.order ?? 99) - (b.data.order ?? 99);
});

const collectionTitle = collection === 'ssg-guide' ? 'SSG Guide' : 'Minecraft Guide';
const slugPrefix = collection === 'ssg-guide' ? 'ssg' : 'mc';
const backHomeLink = collection === 'ssg-guide' ? '/' : '/minecraft/';
---

<Layout title={`${post.data.title} | ${collectionTitle}`}>
  <div class="book-shell">
    <aside class="sidebar">
      <div class="sidebar-header">
        <span class="collection-badge">{collectionTitle}</span>
        <h2 class="sidebar-title">目次</h2>
      </div>
      <nav class="toc-nav">
        {Array.from(new Set(sortedPosts.map(p => p.data.chapter))).sort((a, b) => (a ?? 0) - (b ?? 0)).map(chapterNum => (
          <div class="chapter-group">
            <h3 class="chapter-label">Chapter {chapterNum}</h3>
            <ul>
              {sortedPosts.filter(p => p.data.chapter === chapterNum).map(p => (
                <li>
                  <a href={`/guide/${slugPrefix}/${p.id}`} class={p.id === post.id ? 'active' : ''}>
                    <span class="order-num">{p.data.order}</span>
                    <span class="link-text">{p.data.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
      
      <div class="sidebar-footer">
        <a href={backHomeLink} class="back-home">← 総合目次に戻る</a>
      </div>
    </aside>

    <article class="post-article">
      <header class="post-header">
        <div class="post-meta">
          <span class="chapter-tag">Chapter {post.data.chapter} - Section {post.data.order}</span>
          {post.data.tags && post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        {post.data.summary && <p class="post-description">{post.data.summary}</p>}
      </header>

      <div class="post-content prose prose-slate lg:prose-xl max-w-none">
        <Content components={{ ZennMessage }} />
      </div>

      <Comments />
    </article>
  </div>
</Layout>

<style>
  .book-shell {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* サイドバーのスタイル */
  .sidebar {
    position: sticky;
    top: 2rem;
    height: calc(100vh - 4rem);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    padding-right: 1rem;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
  }

  .collection-badge {
    background: var(--primary);
    color: #fff;
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-weight: bold;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .sidebar-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: #fff;
  }

  .chapter-group {
    margin-bottom: 2rem;
  }

  .chapter-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .toc-nav ul {
    list-style: none;
    padding: 0;
  }

  .toc-nav li {
    margin-bottom: 0.5rem;
  }

  .toc-nav a {
    display: flex;
    gap: 0.75rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.95rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .toc-nav a:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
  }

  .toc-nav a.active {
    background: rgba(99, 102, 241, 0.15);
    color: var(--primary);
    font-weight: 600;
  }

  .order-num {
    opacity: 0.5;
    font-family: var(--font-mono);
  }

  .sidebar-footer {
    margin-top: auto;
    padding-top: 2rem;
  }

  .back-home {
    font-size: 0.9rem;
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
  }

  /* 記事エリア */
  .post-header {
    margin-bottom: 4rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .chapter-tag {
    color: var(--primary);
    font-weight: 700;
  }

  .tag {
    color: var(--text-muted);
    opacity: 0.8;
  }

  .post-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    color: #fff;
  }

  .post-description {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .post-content {
    color: #e2e8f0;
    margin-bottom: 6rem;
  }

  @media (max-width: 900px) {
    .book-shell {
      grid-template-columns: 1fr;
      display: flex;
      flex-direction: column;
    }

    .post-article {
      order: 1;
      padding: 0;
    }

    .sidebar {
      order: 2;
      position: static;
      height: auto;
      margin-top: 6rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 3rem;
    }
  }
</style>
