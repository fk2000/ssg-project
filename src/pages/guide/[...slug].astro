---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Comments from '../../components/Comments.astro';

export async function getStaticPaths() {
  const allGuidePosts = await getCollection('ssg-guide');
  return allGuidePosts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

// サイドバー用に全記事を取得
const allPosts = await getCollection('ssg-guide');
const sortedPosts = allPosts.sort((a, b) => {
  if (a.data.chapter !== b.data.chapter) return (a.data.chapter ?? 0) - (b.data.chapter ?? 0);
  return (a.data.order ?? 0) - (b.data.order ?? 0);
});

// 章ごとにグループ化
const chapters = [...new Set(sortedPosts.map(p => p.data.chapter ?? 0))].sort();

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | SSG Guide`}>
  <div class="book-shell">
    <!-- サイドバー -->
    <aside class="sidebar">
      <div class="sidebar-inner glass-card">
        <h2 class="sidebar-title">目次</h2>
        <nav class="sidebar-nav">
          {chapters.map(chNumber => (
            <details open class="chapter-group">
              <summary class="chapter-header">
                Chapter {chNumber === 0 ? 'Intro' : chNumber}
                <span class="chevron">›</span>
              </summary>
              <ul class="chapter-list">
                {sortedPosts.filter(p => (p.data.chapter ?? 0) === chNumber).map(p => (
                  <li>
                    <a href={`/guide/${p.id}`} class={`nav-link ${p.id === post.id ? 'active' : ''}`}>
                      {p.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))}
        </nav>
      </div>
    </aside>

    <!-- メインコンテンツ -->
    <article class="post-article">
      <header class="post-header">
        <div class="post-breadcrumb">
          <a href="/">Guide</a> / <span class="current">Chapter {post.data.chapter ?? '?'}</span>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-info">
          <span class={`status-tag ${post.data.status}`}>{post.data.status}</span>
        </div>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <Comments />

      <footer class="post-footer">
        <hr class="footer-divider" />
        <div class="footer-actions">
          <a href="/" class="back-link">
            <span class="arrow">←</span> 目次へ戻る
          </a>
        <!-- <a 
            href={`https://bitbucket.org/fk2000/vigorous-venus/src/main/src/content/ssg-guide/${post.id}.md`} 
            target="_blank" 
            class="edit-link"
          >
            <span class="icon">✎</span> このページを編集する
          </a> -->
        </div>
      </footer>
    </article>
  </div>
</Layout>

<style>
  .book-shell {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* サイドバー設定 */
  .sidebar {
    position: sticky;
    top: 6rem;
    height: calc(100vh - 8rem);
  }

  .sidebar-inner {
    height: 100%;
    padding: 2rem;
    overflow-y: auto;
  }

  .sidebar-title {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    color: var(--primary);
  }

  .chapter-group {
    margin-bottom: 1rem;
  }

  .chapter-header {
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    font-size: 0.9rem;
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .chapter-header::-webkit-details-marker { display: none; }

  .chevron {
    transition: transform 0.3s ease;
    font-size: 1.2rem;
    color: var(--text-muted);
  }

  .chapter-group[open] .chevron {
    transform: rotate(90deg);
  }

  .chapter-list {
    list-style: none;
    padding-left: 0.5rem;
    margin: 0.5rem 0 1.5rem 0;
    border-left: 1px solid var(--border);
  }

  .nav-link {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.95rem;
    color: var(--text-muted);
    border-radius: 6px;
    margin-bottom: 2px;
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--primary);
  }

  .nav-link.active {
    background: rgba(99, 102, 241, 0.1);
    color: var(--primary);
    font-weight: 600;
  }

  /* 記事エリア：プロフェッショナル・ペーパー・スタイル */
  .post-article {
    max-width: 800px;
    background: #ffffff; /* 完全な白 */
    color: #1a202c; /* 濃いグレー（文字用） */
    padding: 4rem;
    border-radius: 12px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .post-title {
    font-size: 3rem;
    margin-bottom: 1rem;
    font-weight: 800;
    line-height: 1.2;
    color: #0f172a; /* 非常に濃い紺 */
    background: none;
    -webkit-text-fill-color: initial;
  }

  .post-content {
    font-size: 1.125rem;
    line-height: 1.85;
    color: #334155;
  }

  .post-content h2 {
    font-size: 1.75rem;
    margin: 3.5rem 0 1.25rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #6366f1;
    color: #0f172a;
  }

  .post-content h3 {
    font-size: 1.35rem;
    margin: 2rem 0 1rem 0;
    color: #4338ca;
  }

  .post-content p {
    margin-bottom: 1.5rem;
  }

  .post-content strong {
    color: #000;
    font-weight: 700;
    background: linear-gradient(120deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0.1) 100%);
    padding: 0 2px;
  }

  .post-content ul, .post-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content li {
    margin-bottom: 0.75rem;
  }

  .post-content blockquote {
    margin: 2.5rem 0;
    padding: 1.5rem 2rem;
    background: #f8fafc;
    border-left: 4px solid #6366f1;
    border-radius: 4px;
    font-style: normal;
    color: #475569;
  }

  .post-content code:not(pre code) {
    background: #f1f5f9;
    color: #e11d48;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.9em;
  }

  .footer-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .back-link, .edit-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: var(--on-surface);
    opacity: 0.7;
    font-size: 0.95rem;
  }

  .edit-link {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .back-link:hover, .edit-link:hover {
    opacity: 1;
    color: var(--primary);
  }

  .edit-link:hover {
    background: rgba(99, 102, 241, 0.1);
    border-color: var(--primary);
  }

  .arrow, .icon {
    transition: transform 0.3s ease;
  }

  .back-link:hover .arrow {
    transform: translateX(-5px);
  }

  .edit-link:hover .icon {
    transform: rotate(15deg) scale(1.1);
  }

  @media (max-width: 900px) {
    .book-shell {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
      height: auto;
      margin-bottom: 3rem;
    }
  }
</style>
